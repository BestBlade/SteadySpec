{
  "name": "steadyspec",
  "version": "0.7.0",
  "private": true,
  "description": "Source-distributed anti-drift five-flow SDD lifecycle with optional agent assurance.",
  "bin": {
    "steadyspec": "bin/init.js"
  },
  "scripts": {
    "test": "npm run validate",
    "test:portability": "node tests/portability-fixtures.js",
    "validate": "node bin/validate.js --suite all",
    "validate:assurance": "node bin/validate.js --suite assurance",
    "validate:contract": "node bin/validate.js --suite contract",
    "validate:cross-review": "node bin/validate.js --suite cross-review",
    "validate:closure": "node bin/validate.js --suite closure",
    "validate:install": "node bin/validate.js --suite install",
    "validate:portability": "node bin/validate.js --suite portability"
  },
  "keywords": [
    "sdd",
    "spec-driven-development",
    "drift",
    "agent-skills",
    "agent-assurance",
    "codex",
    "claude"
  ],
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/BestBlade/SteadySpec.git"
  },
  "bugs": {
    "url": "https://github.com/BestBlade/SteadySpec/issues"
  },
  "homepage": "https://github.com/BestBlade/SteadySpec#readme",
  "files": [
    "bin/",
    "tests/",
    "release-evidence/",
    "protocol/",
    "schemas/",
    "en/",
    "zh/",
    "recipes/",
    "METHOD.md",
    "PRODUCT.md",
    "CHANGELOG.md",
    "ARTIFACT_CONTRACT.md",
    "manifest.json",
    "README.md",
    "SCOPE.md",
    "QUICKSTART.md",
    "EVIDENCE.md",
    "LICENSE"
  ],
  "license": "MIT"
}
