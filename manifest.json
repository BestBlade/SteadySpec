{
  "name": "steadyspec",
  "version": "0.2.1",
  "description": "Anti-drift methodology packaged as a software SDD reference implementation.",
  "languages": ["en"],
  "install": {
    "defaultLayout": "flat-runtime-skills",
    "skillPrefix": "steadyspec",
    "entrySkill": "steadyspec-adopt",
    "routerSkill": "steadyspec-workflow",
    "copyOnly": true,
    "runtimeAdapters": {
      "claude": {
        "commandsSource": "runtime/claude/commands/steadyspec",
        "commandsTarget": ".claude/commands/steadyspec"
      },
      "codex": {
        "agentsSource": "runtime/codex/agents",
        "agentsTargetSubpath": "agents/openai.yaml"
      }
    },
    "workflows": {
      "claude": {
        "source": "runtime/claude/workflows",
        "target": ".claude/workflows"
      }
    }
  },
  "skills": [
    "adoption/steadyspec-adopt",
    "router/steadyspec-workflow",
    "primitives/steadyspec-apply",
    "primitives/steadyspec-archive",
    "primitives/steadyspec-context-archaeology",
    "primitives/steadyspec-debate",
    "primitives/steadyspec-doc-sync",
    "primitives/steadyspec-explore",
    "primitives/steadyspec-grill",
    "primitives/steadyspec-human-decision-record",
    "primitives/steadyspec-propose",
    "primitives/steadyspec-review-against-intent",
    "primitives/steadyspec-strategy-rollup"
  ],
  "flows": [
    "flows/steadyspec-explore-flow",
    "flows/steadyspec-propose-flow",
    "flows/steadyspec-apply-flow",
    "flows/steadyspec-archive-flow"
  ],
  "workflows": [
    "runtime/claude/workflows/steadyspec-explore.js",
    "runtime/claude/workflows/steadyspec-propose.js",
    "runtime/claude/workflows/steadyspec-apply.js",
    "runtime/claude/workflows/steadyspec-archive.js"
  ]
}
