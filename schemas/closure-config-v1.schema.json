{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://steadyspec.dev/schemas/closure-config-v1.schema.json",
  "title": "SteadySpec closure project config v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "mode", "acceptanceProfile", "limits", "proofPolicies"],
  "properties": {
    "schemaVersion": { "const": 1 },
    "mode": { "enum": ["off", "manual", "auto"] },
    "acceptanceProfile": { "type": "string", "minLength": 1 },
    "limits": {
      "type": "object",
      "additionalProperties": false,
      "required": ["maxCycles", "wallClockMs", "maxAutoFiles", "recurrenceLimit", "noProgressCycles"],
      "properties": {
        "maxCycles": { "type": "integer", "minimum": 1, "maximum": 20 },
        "wallClockMs": { "type": "integer", "minimum": 60000 },
        "maxAutoFiles": { "type": "integer", "minimum": 1 },
        "recurrenceLimit": { "type": "integer", "minimum": 1 },
        "noProgressCycles": { "type": "integer", "minimum": 1 }
      }
    },
    "proofPolicies": { "type": "object" },
    "generatedTemplate": { "type": "boolean" },
    "reviewRequired": { "type": "boolean" },
    "boundary": { "type": "string" }
  }
}
