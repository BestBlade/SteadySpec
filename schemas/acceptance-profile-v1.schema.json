{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://steadyspec.dev/schemas/acceptance-profile-v1.schema.json",
  "title": "SteadySpec acceptance profile v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "id", "candidatePaths", "dimensions"],
  "properties": {
    "schemaVersion": { "const": 1 },
    "id": { "type": "string", "minLength": 1 },
    "candidatePaths": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
    "dimensions": {
      "type": "array",
      "minItems": 6,
      "maxItems": 6,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "required", "proofPolicyIds", "requiredSourceClasses", "coverageLimit"],
        "properties": {
          "id": { "enum": ["requirement-completeness", "logic-correctness", "edge-cases", "code-quality", "test-coverage", "actual-runtime-result"] },
          "required": { "type": "boolean" },
          "proofPolicyIds": { "type": "array", "items": { "type": "string" } },
          "requiredSourceClasses": { "type": "array", "items": { "type": "string" } },
          "coverageLimit": { "type": "string", "minLength": 1 }
        }
      }
    }
  }
}
